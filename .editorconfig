# EditorConfig is awesome: https://EditorConfig.org

# 顶层配置文件
root = true

[*]
# 字符集
charset = utf-8
# 缩进风格：空格
indent_style = space
# 缩进大小：2个空格
indent_size = 2
# 换行符：lf (Linux/macOS风格)
end_of_line = lf
# 文件以换行符结束
insert_final_newline = true
# 去除行尾空格
trim_trailing_whitespace = true
# 最大行长度
max_line_length = 100

[*.md]
# Markdown 文件不强制去除行尾空格（可能影响列表格式）
trim_trailing_whitespace = false

[*.{html,htm}]
# HTML 文件缩进为2空格
indent_size = 2

[*.{json,json5}]
# JSON 文件缩进为2空格
indent_size = 2

[*.{yml,yaml}]
# YAML 文件缩进为2空格
indent_size = 2

[*.{py}]
# Python 文件配置
indent_size = 4

[Makefile]
# Makefile 必须使用 Tab 缩进
indent_style = tab

[{package.json,package-lock.json}]
# npm 配置文件保持原格式
indent_style = space
indent_size = 2