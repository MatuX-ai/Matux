# 生产环境配置文件
# 请将此文件复制为 .env.production 并填入实际值

# 应用配置
APP_NAME=iMato AI Service Production
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_URL=postgresql://neondb_owner:npg_gOwZRiQYy8W3@ep-dark-violet-a13zs25i-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT配置
SECRET_KEY=your-production-secret-key-change-this-immediately
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI配置
OPENAI_API_KEY=sk-prod-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Lingma配置
LINGMA_API_KEY=your-production-lingma-api-key
LINGMA_MODEL=lingma-code-pro
LINGMA_TEMPERATURE=0.7
LINGMA_MAX_TOKENS=2000

# DeepSeek配置
DEEPSEEK_API_KEY=your-production-deepseek-api-key
DEEPSEEK_MODEL=deepseek-coder
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=2000

# Anthropic配置
ANTHROPIC_API_KEY=your-production-anthropic-api-key
ANTHROPIC_MODEL=claude-3-opus-20240229
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_MAX_TOKENS=2000

# Google配置
GOOGLE_API_KEY=your-production-google-api-key
GOOGLE_MODEL=gemini-pro
GOOGLE_TEMPERATURE=0.7
GOOGLE_MAX_TOKENS=2000

# CORS配置
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=/var/log/ai_service/production.log

# 速率限制配置
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=3600

# 缓存配置
REDIS_URL=redis://localhost:6379/0

# 监控配置
ENABLE_MONITORING=True
SENTRY_DSN=your-sentry-dsn-here

# 备份配置
BACKUP_ENABLED=True
BACKUP_SCHEDULE="0 2 * * *"  # 每天凌晨2点备份
BACKUP_RETENTION_DAYS=30

# SSL配置
SSL_CERTIFICATE_PATH=/etc/ssl/certs/your-cert.pem
SSL_PRIVATE_KEY_PATH=/etc/ssl/private/your-key.pem