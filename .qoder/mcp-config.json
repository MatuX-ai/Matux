{
  "mcpServers": {
    "browser-use": {
      "name": "browser-use",
      "description": "浏览器自动化工具集 - 用于测试前端页面、验证登录流程、截图、页面分析等",
      "enabled": true,
      "source": "built-in",
      "tools": [
        {
          "name": "navigate_page",
          "description": "导航到指定URL - 用于测试登录页面、仪表板等",
          "useCase": "测试登录流程、自动导航到Dashboard"
        },
        {
          "name": "click",
          "description": "点击页面元素 - 用于点击登录按钮、一键登录等",
          "useCase": "触发登录操作、导航菜单"
        },
        {
          "name": "fill",
          "description": "填写表单字段 - 用于自动填入测试账号信息",
          "useCase": "填写用户名、密码字段"
        },
        {
          "name": "take_screenshot",
          "description": "截图当前页面 - 用于记录测试结果、验证UI",
          "useCase": "登录后截图、仪表板效果验证"
        },
        {
          "name": "take_snapshot",
          "description": "获取页面快照 - 用于分析页面结构",
          "useCase": "检查DOM元素、验证组件渲染"
        },
        {
          "name": "list_network_requests",
          "description": "列出网络请求 - 用于分析API调用性能",
          "useCase": "分析登录API耗时、检查Dashboard数据加载"
        },
        {
          "name": "list_console_messages",
          "description": "列出控制台消息 - 用于调试JavaScript错误",
          "useCase": "查看登录日志、分析错误信息"
        },
        {
          "name": "list_pages",
          "description": "列出所有打开的页面",
          "useCase": "管理多标签页测试"
        },
        {
          "name": "select_page",
          "description": "选择指定页面",
          "useCase": "切换测试目标页面"
        },
        {
          "name": "handle_dialog",
          "description": "处理对话框 - 用于处理浏览器弹窗",
          "useCase": "处理登录确认弹窗"
        },
        {
          "name": "wait_for",
          "description": "等待指定条件",
          "useCase": "等待页面加载完成、等待API响应"
        },
        {
          "name": "evaluate_script",
          "description": "执行JavaScript代码",
          "useCase": "检查localStorage、检查认证状态"
        },
        {
          "name": "press_key",
          "description": "按键操作",
          "useCase": "模拟键盘输入、回车登录"
        },
        {
          "name": "hover",
          "description": "悬停操作",
          "useCase": "触发悬停效果、显示下拉菜单"
        },
        {
          "name": "drag",
          "description": "拖拽操作",
          "useCase": "测试拖拽功能"
        },
        {
          "name": "upload_file",
          "description": "上传文件",
          "useCase": "测试文件上传功能"
        }
      ],
      "useCases": {
        "登录测试": {
          "steps": [
            "1. navigate_page 到 http://localhost:4200/auth/login",
            "2. 截图确认登录页面",
            "3. click 一键登录按钮",
            "4. wait_for 3秒让登录完成",
            "5. navigate_page 到 /user/dashboard",
            "6. take_screenshot 验证Dashboard"
          ],
          "expectedResult": "成功登录并显示学生仪表板"
        },
        "性能分析": {
          "steps": [
            "1. list_network_requests 开始监听",
            "2. 触发一键登录",
            "3. 分析 /api/v1/auth/token 请求耗时",
            "4. 分析 /api/v1/auth/me 请求耗时",
            "5. 分析 Dashboard API 请求耗时"
          ],
          "expectedResult": "生成详细的性能报告"
        },
        "UI验证": {
          "steps": [
            "1. 登录成功后截图",
            "2. take_snapshot 获取完整DOM",
            "3. list_console_messages 检查是否有错误",
            "4. evaluate_script 检查localStorage中的认证信息"
          ],
          "expectedResult": "验证UI正常、无控制台错误"
        }
      }
    }
  },
  "projectConfig": {
    "projectType": "Angular + Electron + Python",
    "frontend": {
      "framework": "Angular 21",
      "devServer": "http://localhost:4200",
      "apiBase": "http://localhost:8000/api"
    },
    "electron": {
      "mainProcess": "g:\\iMato\\electron\\main.js",
      "preloadScripts": [
        "g:\\iMato\\electron\\preload.js",
        "g:\\iMato\\electron\\preload-splash.js"
      ]
    },
    "backend": {
      "framework": "FastAPI (Python)",
      "baseUrl": "http://localhost:8000",
      "authEndpoint": "/api/v1/auth/token",
      "userEndpoint": "/api/v1/auth/me"
    },
    "testAccounts": {
      "student": {
        "username": "test_student",
        "password": "TestStudent123!",
        "role": "STUDENT",
        "description": "学习端学生测试账号"
      },
      "teacher": {
        "username": "test_teacher",
        "password": "TestTeacher123!",
        "role": "TEACHER",
        "description": "教师测试账号"
      },
      "admin": {
        "username": "test_admin",
        "password": "TestAdmin123!",
        "role": "ADMIN",
        "description": "管理员测试账号"
      }
    }
  },
  "automationScenarios": {
    "一键登录验证": {
      "description": "验证一键登录功能是否正常工作",
      "url": "http://localhost:4200/auth/login",
      "actions": [
        {"type": "navigate", "url": "http://localhost:4200/auth/login"},
        {"type": "screenshot", "filename": "login-page-before"},
        {"type": "click", "selector": ".test-login-button"},
        {"type": "wait", "seconds": 3},
        {"type": "screenshot", "filename": "login-page-after"},
        {"type": "navigate", "url": "http://localhost:4200/user/dashboard"},
        {"type": "wait", "seconds": 2},
        {"type": "screenshot", "filename": "dashboard"}
      ]
    },
    "登录性能测试": {
      "description": "测量一键登录各环节耗时",
      "actions": [
        {"type": "clearNetworkLog"},
        {"type": "click", "selector": ".test-login-button"},
        {"type": "startTimer", "name": "total"},
        {"type": "waitForNetwork", "urlPattern": "/api/v1/auth/token"},
        {"type": "stopTimer", "name": "token"},
        {"type": "waitForNetwork", "urlPattern": "/api/v1/auth/me"},
        {"type": "stopTimer", "name": "fetchUser"},
        {"type": "stopTimer", "name": "total"},
        {"type": "getNetworkLog"},
        {"type": "report", "timers": ["token", "fetchUser", "total"]}
      ]
    },
    "Dashboard数据加载验证": {
      "description": "验证Dashboard的各类数据是否正常加载",
      "url": "http://localhost:4200/user/dashboard",
      "checks": [
        {"type": "api", "endpoint": "/api/v1/ai-edu/progress/stats", "name": "进度统计"},
        {"type": "api", "endpoint": "/api/v1/ai-edu/learning-sources", "name": "学习源"},
        {"type": "api", "endpoint": "/api/v1/courses/enrollments", "name": "课程列表"},
        {"type": "check", "selector": ".student-dashboard", "name": "Dashboard容器"},
        {"type": "check", "selector": ".stats-card", "name": "统计卡片"},
        {"type": "check", "selector": ".course-card", "name": "课程卡片"}
      ]
    }
  },
  "metadata": {
    "created": "2026-06-08",
    "version": "1.0.0",
    "author": "MatuX Development Team",
    "purpose": "前端自动化测试、登录流程验证、性能分析"
  }
}
