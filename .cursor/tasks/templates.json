{
  "version": "1.0.0",
  "templates": {
    "feature-development": {
      "name": "功能开发任务",
      "description": "标准的功能开发任务模板",
      "steps": [
        "需求分析和任务分解",
        "技术方案设计",
        "代码实现",
        "单元测试编写",
        "集成测试",
        "代码审查",
        "文档更新",
        "部署上线"
      ],
      "checklist": [
        "需求文档是否完整",
        "技术方案是否可行",
        "代码是否符合规范",
        "测试用例是否覆盖",
        "文档是否及时更新"
      ]
    },
    "bug-fix": {
      "name": "Bug修复任务",
      "description": "标准的Bug修复任务模板",
      "steps": [
        "问题复现和定位",
        "根本原因分析",
        "修复方案设计",
        "代码修改",
        "回归测试",
        "代码审查",
        "部署验证"
      ],
      "checklist": [
        "问题是否能稳定复现",
        "修复方案是否合理",
        "是否有回归风险",
        "测试用例是否补充"
      ]
    },
    "refactor": {
      "name": "代码重构任务",
      "description": "标准的代码重构任务模板",
      "steps": [
        "现状分析",
        "重构目标确定",
        "重构方案设计",
        "逐步重构实施",
        "测试验证",
        "性能对比",
        "文档更新"
      ],
      "checklist": [
        "重构目标是否明确",
        "是否有充分的测试覆盖",
        "性能是否有所提升",
        "代码可读性是否改善"
      ]
    },
    "documentation": {
      "name": "文档编写任务",
      "description": "标准的文档编写任务模板",
      "steps": [
        "文档需求分析",
        "大纲设计",
        "内容撰写",
        "技术审核",
        "格式美化",
        "版本发布"
      ],
      "checklist": [
        "文档结构是否清晰",
        "内容是否准确完整",
        "语言表达是否通俗易懂",
        "是否有实用示例"
      ]
    }
  }
}