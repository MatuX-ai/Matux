# iMato Cloud 生产环境变量配置模板
# 复制此文件为 .env.production 并修改实际值
# cp .env.example .env.production

# ============================================
# 应用配置
# ============================================
APP_ENV=production
LOG_LEVEL=info
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# 数据库配置
# ============================================
POSTGRES_USER=imato
POSTGRES_PASSWORD=change-this-to-a-secure-password
POSTGRES_DB=imato_cloud
DB_EXTERNAL_PORT=5432

# ============================================
# Redis 配置
# ============================================
REDIS_PASSWORD=change-this-to-another-secure-password
REDIS_EXTERNAL_PORT=6379

# ============================================
# Grafana 监控配置
# ============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=secure-grafana-password

# ============================================
# Token 计费配置
# ============================================
TOKEN_BONUS_ENABLED=true
TOKEN_FREE_AMOUNT=100
TOKEN_STANDARD_AMOUNT=1000
TOKEN_PREMIUM_AMOUNT=5000
TOKEN_ENTERPRISE_AMOUNT=20000

# ============================================
# AI 服务降级配置
# ============================================
AI_FALLBACK_ENABLED=true
AI_MAX_RETRIES=3
AI_TIMEOUT_SECONDS=30

# ============================================
# Celery 异步任务配置
# ============================================
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_POOL=eventlet
CELERY_BEAT_SCHEDULE_ENABLED=true

# ============================================
# 文件上传配置
# ============================================
MAX_UPLOAD_SIZE_MB=100
UPLOAD_DIR=/app/backend/uploads

# ============================================
# Nginx 配置
# ============================================
NGINX_WORKER_PROCESSES=auto
NGINX_KEEPALIVE_TIMEOUT=65
NGINX_CLIENT_MAX_BODY_SIZE_MB=100
