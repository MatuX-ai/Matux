{
    "name": "imatuproject-design-system",
    "version": "1.0.0",
    "description": "iMatuProject Design Token and Style System",
    "main": "src/design-tokens/index.ts",
    "scripts": {
        "start": "ng serve",
        "serve": "ng serve",
        "dev": "ng serve --host 0.0.0.0",
        "dev:all": "concurrently \"npm run dev\" \"cd backend && python run.py\"",
        "dev:backend": "cd backend && python run.py",
        "dev:frontend": "ng serve --host 0.0.0.0",
        "build": "ng build",
        "build:prod": "ng build --configuration production",
        "test": "echo \"No tests specified\" && exit 0",
        "clean": "rimraf dist",
        "lint": "npm run lint:ts && npm run lint:scss",
        "lint:ts": "eslint src/**/*.ts --fix",
        "lint:ts-check": "eslint src/**/*.ts",
        "lint:ts-report": "eslint src/**/*.ts --format unix",
        "lint:scss": "stylelint \"src/**/*.scss\" --fix --cache",
        "lint:scss-check": "stylelint \"src/**/*.scss\" --cache",
        "lint:scss-report": "stylelint \"src/**/*.scss\" --formatter verbose",
        "format": "prettier --write \"src/**/*.{ts,html,scss,json,md}\"",
        "format:check": "prettier --check \"src/**/*.{ts,html,scss,json,md}\"",
        "quality:check": "npm run lint:ts-check && npm run lint:scss-check && npm run format:check",
        "quality:fix": "npm run format && npm run lint",
        "lint:css": "npm run lint:scss",
        "lint:css-fix": "npm run lint:scss",
        "lint:css-report": "npm run lint:scss-report",
        "precommit:check": "python scripts/precommit_checker.py",
        "quality:trend": "python scripts/quality_trend_analyzer.py",
        "quality:thresholds": "python scripts/dynamic_quality_thresholds.py",
        "icons:download": "node scripts/download-icons.js"
    },
    "keywords": [
        "design-tokens",
        "design-system",
        "education"
    ],
    "author": "iMatuProject Team",
    "license": "GPL-3.0",
    "dependencies": {
        "@angular/animations": "^21.2.1",
        "@angular/cdk": "^21.2.1",
        "@angular/common": "^21.2.1",
        "@angular/compiler": "^21.2.5",
        "@angular/core": "^21.2.5",
        "@angular/forms": "^21.2.1",
        "@angular/material": "^21.2.1",
        "@angular/platform-browser": "^21.2.1",
        "@angular/platform-browser-dynamic": "^21.2.1",
        "@angular/router": "^21.2.1",
        "@angular/service-worker": "^21.2.1",
        "@types/three": "^0.183.1",
        "adm-zip": "^0.5.17",
        "axios": "^1.15.0",
        "blockly": "^12.5.1",
        "chart.js": "^4.5.1",
        "dompurify": "^3.3.3",
        "echarts": "^6.0.0",
        "exceljs": "^4.4.0",
        "file-saver": "^2.0.5",
        "jspdf": "^4.2.1",
        "monaco-editor": "^0.50.0",
        "ng2-charts": "^6.0.0",
        "ngx-echarts": "^21.0.0",
        "ngx-image-cropper": "^9.1.6",
        "ngx-monaco-editor-v2": "^21.0.0",
        "pptxgenjs": "^4.0.1",
        "remixicon": "^4.9.1",
        "rxjs": "~7.8.0",
        "three": "^0.183.2",
        "tslib": "^2.3.0",
        "xlsx": "^0.18.5",
        "zone.js": "~0.16.0"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "^21.2.3",
        "@angular/cli": "^21.2.3",
        "@angular/compiler-cli": "^21.2.1",
        "@types/chart.js": "^2.9.41",
        "@types/echarts": "^4.9.22",
        "@types/file-saver": "^2.0.7",
        "@types/jasmine": "~5.1.0",
        "@types/jspdf": "^1.3.3",
        "@types/node": "^20.0.0",
        "@types/xlsx": "^0.0.35",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "concurrently": "^9.2.1",
        "electron": "^42.3.3",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "eslint-plugin-simple-import-sort": "^12.0.0",
        "eslint-plugin-unused-imports": "^3.0.0",
        "husky": "^9.1.7",
        "jasmine-core": "~5.1.0",
        "karma": "~6.4.0",
        "karma-chrome-launcher": "~3.2.0",
        "karma-coverage": "~2.2.0",
        "karma-jasmine": "~5.1.0",
        "karma-jasmine-html-reporter": "~2.1.0",
        "lint-staged": "^15.2.0",
        "postcss": "^8.5.6",
        "postcss-scss": "^4.0.9",
        "prettier": "3.8.1",
        "rimraf": "^5.0.5",
        "stylelint": "^17.4.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-declaration-strict-value": "^1.11.1",
        "stylelint-order": "^7.0.1",
        "typescript": "~5.9.3"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{scss,css}": [
            "stylelint --fix",
            "prettier --write"
        ],
        "*.{json,md,html,yml,yaml}": [
            "prettier --write"
        ]
    },
    "overrides": {
        "dompurify": "^3.3.3"
    }
}
