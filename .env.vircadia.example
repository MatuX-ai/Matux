# Vircadia Metaverse Environment Variables
# Version: 1.0
# Last Updated: 2026-03-03
# Description: Environment configuration for Vircadia local deployment

# IMPORTANT: Copy this file to .env.vircadia and update values for production use
# DO NOT commit .env.vircadia to version control

#==============================================================================
# Database Configuration
#==============================================================================
VIRCADIA_DB_PASSWORD=vircadia_secret_2026_change_me_in_production

#==============================================================================
# API Authentication
#==============================================================================
VIRCADIA_API_KEY=dev_api_key_change_in_production
VIRCADIA_JWT_SECRET=jwt_secret_change_in_production_use_strong_random_string

#==============================================================================
# Server Configuration
#==============================================================================
VIRCADIA_SERVER_NAME=iMatu Virtual Campus
VIRCADIA_SERVER_URL=http://localhost:9000
VIRCADIA_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:4200

#==============================================================================
# Feature Flags
#==============================================================================
VIRCADIA_ENABLE_AVATAR_CUSTOMIZATION=true
VIRCADIA_ENABLE_VOICE_CHAT=true
VIRCADIA_ENABLE_MULTIPLAYER=true
VIRCADIA_DEFAULT_SCENE=welcome-center

#==============================================================================
# Logging
#==============================================================================
VIRCADIA_LOG_LEVEL=info
VIRCADIA_LOG_FILE=/var/log/vircadia/server.log

#==============================================================================
# Development Mode (Set to false in production)
#==============================================================================
VIRCADIA_DEBUG=true
VIRCADIA_DEV_MODE=true
