{
  "name": "imato-desktop",
  "version": "1.0.0",
  "description": "iMato Windows Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --config electron-builder.yml",
    "build:portable": "electron-builder --win portable --config electron-builder.yml",
    "build:all": "npm run build && npm run build:portable",
    "clean": "rimraf dist"
  },
  "keywords": [
    "electron",
    "imato",
    "education",
    "desktop"
  ],
  "author": "iMatu Development Team",
  "license": "GPL-3.0",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "js-yaml": "^4.1.0"
  },
  "dependencies": {
    "wait-port": "^1.1.0",
    "electron-updater": "^6.1.0"
  }
}
